RewriteEngine On

# Force HTTPS on production (avoid Secure cookie loss on http)
RewriteCond %{HTTP_HOST} !^localhost$ [NC]
RewriteCond %{HTTP_HOST} !^127\.0\.0\.1$ [NC]
RewriteCond %{HTTPS} !=on
RewriteCond %{HTTP:X-Forwarded-Proto} !https
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Force www on production to keep a single session cookie host
RewriteCond %{HTTP_HOST} ^sested-eja\.com$ [NC]
RewriteRule ^ https://www.sested-eja.com%{REQUEST_URI} [L,R=301]

# Maintenance mode (site offline)
#RewriteCond %{REQUEST_URI} !/maintenance.html$ [NC]
#RewriteRule ^.*$ /maintenance.html [R=503,L]
#ErrorDocument 503 /maintenance.html
#Header always set Retry-After "3600"
#RewriteCond %{REQUEST_FILENAME} !-f
#RewriteCond %{REQUEST_FILENAME} !-d


RewriteRule ^contatos(.*)$ contatos.php [L]
RewriteRule ^index(.*)$ index.php [L]
RewriteRule ^index.php(.*)$ index.php [L]

RewriteRule ^sobre(.*)$ sobre.php [L]
RewriteRule ^parcerias(.*)$ parcerias.php [L]
RewriteRule ^planos(.*)$ planos.php [L]
RewriteRule ^perguntas(.*)$ perguntas.php [L]
RewriteRule ^politica(.*)$ politica.php [L]
RewriteRule ^termos(.*)$ termos.php [L]
RewriteRule ^pacotes(.*)$ pacotes.php [L]
RewriteRule ^lista-cursos(.*)$ lista-cursos.php [L]
RewriteRule ^formacoes(.*)$ formacoes.php [L]
RewriteRule ^sistemas(.*)$ sistemas.php [L]
RewriteRule ^cursos-2021(.*)$ cursos-2021.php [L]
RewriteRule ^cursos-2022(.*)$ cursos-2022.php [L]
RewriteRule ^linguagens(.*)$ linguagens.php [L]


RewriteRule ^curso-de-(.*)$ curso.php?url=$1 [L]
RewriteRule ^cursos-do-(.*)$ pacote.php?url=$1 [L]
RewriteRule ^categoria-(.*)$ categoria.php?url=$1 [L]
RewriteRule ^linguagem-(.*)$ linguagem.php?url=$1 [L]

RewriteRule ^cursos(.*)$ cursos.php [L]
RewriteRule ^tecnicos(.*)$ tecnicos.php [L]
RewriteRule ^categorias(.*)$ categorias.php [L]

RewriteRule ^consultar-certificados(.*)$ consultar-certificados.php [L]
RewriteRule ^certificado/(.*)$ sistema/rel/rel_certificado.php?url=$1 [L]

<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
  Header always set X-XSS-Protection "1; mode=block"
  Header always set Strict-Transport-Security "max-age=15552000; includeSubDomains" env=HTTPS
</IfModule>

# php -- BEGIN cPanel-generated handler, do not edit
# Set the “ea-php82” package as the default “PHP” programming language.
<IfModule mime_module>
  AddHandler application/x-httpd-ea-php82___lsphp .php .php8 .phtml
</IfModule>
# php -- END cPanel-generated handler, do not edit
